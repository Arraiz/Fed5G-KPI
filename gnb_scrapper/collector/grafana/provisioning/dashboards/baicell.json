            "uid": "PAD3349F0AAE9DF1D"
          },
          "query": "from(bucket: \"gnb_metrics\")\n  |> range(start: -10m)\n  |> filter(fn: (r) => r._measurement == \"gnb_config\")\n  |> filter(fn: (r) => r.gnb_host == \"${gnb}\")\n  |> filter(fn: (r) => r._field != \"gnb_host\" and r._field != \"target_name\")\n  |> last()\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> drop(columns: [\"_start\", \"_stop\", \"_time\"])",
