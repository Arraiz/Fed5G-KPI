# gNB SSH
# Preferred robust format (handles commas/pipes in passwords):
# BAICELL_TARGETS_JSON=[{"host":"192.168.22.200","user":"userA","password":"passA","port":27149,"target_name":"site_madrid_01"},{"host":"192.168.22.201","user":"userB","password":"passB","target_name":"site_madrid_02"}]
BAICELL_TARGETS_JSON=
BAICELL_IP=192.168.22.200,192.168.22.201
# Prefer this format for per-antenna credentials:
# BAICELL_TARGETS=192.168.22.200|userA|passA,192.168.22.201|userB|passB
BAICELL_TARGETS=
SSH_PORT=27149
SSH_USER=new_user
SSH_PASS=your_password_here

# Scraper
# Preferred scan interval (seconds)
SCRAPE_INTERVAL=20
# Legacy fallback (still supported)
COLLECT_INTERVAL=20

# Vankom scraper (read-only)
# captcha_code=1111 may work even when captcha verify returns non-200
# network_params are written to measurement vankom_config
VANKOM_TARGETS_JSON=[{"target_name":"vankom_01","base_url":"http://192.168.25.50","username":"admin","password":"lmt_2023","captcha_code":"1111","verify_tls":false,"status_xpath":"/oam:Device/Services/FAPService[name='3333']/CellState/BBU","network_params":{"arfcn_dl":"/duoam:InternetGatewayDevice/Services/FAPService[name='3333']/CellConfig/FIVEGNR/RAN/CommonInfo/NRModeInfo/NRArfcnDL","arfcn_ul":"/duoam:InternetGatewayDevice/Services/FAPService[name='3333']/CellConfig/FIVEGNR/RAN/CommonInfo/NRModeInfo/NRArfcnUL"},"param_xpaths":[]}]
VANKOM_SCRAPE_INTERVAL=20

# InfluxDB 2.x
INFLUX_ORG=baicell
INFLUX_BUCKET=gnb_metrics
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=changeme123
INFLUX_TOKEN=baicell-super-secret-token-changeme

# Grafana
GRAFANA_PASSWORD=admin
